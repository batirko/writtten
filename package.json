{
  "name": "writtten",
  "version": "0.8.0",
  "description": "A local-first writing tool where you do all the writing and the AI only reacts, flagging contradictions, unsupported claims, and gaps. It never rewrites your prose.",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:record": "vitest run --reporter=verbose --config vitest.record.config.ts",
    "eval:live": "EVAL_LIVE=1 vitest run src/services/evalRatchet.live.test.ts",
    "eval:v1": "EVAL_V1=1 vitest run src/services/evalV1Corpus.live.test.ts",
    "live-check": "bash scripts/live-check.sh",
    "release:check": "npm run lint && npm test && npm run build && npm run live-check",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@fontsource-variable/faustina": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tiptap/core": "^2.10.4",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/react": "^2.10.4",
    "@tiptap/starter-kit": "^2.10.4",
    "@tiptap/suggestion": "^2.27.2",
    "idb": "^8.0.0",
    "jsdom": "^29.1.1",
    "nanoid": "^5.0.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tiptap-markdown": "^0.8.10",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.27.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.1"
  }
}
