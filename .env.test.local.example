# Live-model test keys. Copy this file to `.env.test.local` (same folder) and
# fill in the keys you have. `.env.test.local` is gitignored — it never commits.
#
# Used ONLY by `npm run live-check` (scripts/live-check.sh), which sources it
# into the shell without printing values, then runs src/model/livecheck.live.test.ts.
# These are NOT read by the app / dev server — that's `.env.local`.
#
# Plain (non-VITE_) names on purpose: a VITE_-prefixed var would get inlined
# into the production bundle (dist/). Leave any key blank to skip that provider.

# OpenAI — use a spend-capped *project* key, not your primary key.
OPENAI_API_KEY=

# Google AI Studio (Gemini). If blank, falls back to VITE_GEMINI_API_KEY in .env.local.
GEMINI_API_KEY=

# Anthropic.
ANTHROPIC_API_KEY=
